# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

app-example
coverage/
ml/.venv/
ml/.pytest_cache/
ml/src/__pycache__/
ml/tests/__pycache__/
# Ignore raw datasets under ml/data, but step-wise re-include the small
# extracted stress feature CSVs (needed by CI training). Git can't re-include a
# file whose parent dir is excluded, so each level excludes /* then re-includes.
ml/data/*
!ml/data/features/
ml/data/features/*
!ml/data/features/stress/
ml/data/features/stress/*
!ml/data/features/stress/*.csv
!ml/data/features/depression/
ml/data/features/depression/*
!ml/data/features/depression/*.csv
ml/**/models/*.joblib
ml/models/*.joblib
__pycache__/
*.pyc
wearos/app/build/
wearos/.gradle/
wearos/.idea/
android/
.env

# Large ML training data (download from the dataset sources; see model cards).
# Keep the small extracted feature CSVs (focus/bioage) — raw subfolders stay out.
ml/*/data/
!ml/focus/data/
ml/focus/data/*
!ml/focus/data/*.csv
!ml/bioage/data/
ml/bioage/data/*
!ml/bioage/data/*.csv
# Generated native iOS project (Expo managed workflow)
/ios/
# Logs and Office temp/lock files
ml/**/*.log
~$*
