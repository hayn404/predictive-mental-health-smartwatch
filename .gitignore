# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

app-example
coverage/
ml/.venv/
ml/.pytest_cache/
ml/src/__pycache__/
ml/tests/__pycache__/
# Raw datasets under ml/data stay out of git. The extracted feature files are
# DVC-tracked (DagsHub remote), so git keeps only the small *.dvc pointers.
ml/data/*
!ml/data/features/
ml/data/features/*
!ml/data/features/*.dvc
ml/**/models/*.joblib
ml/models/*.joblib
__pycache__/
*.pyc
wearos/app/build/
wearos/.gradle/
wearos/.idea/
android/
.env

# Large ML training data (download from the dataset sources; see model cards).
# Extracted focus/bioage feature CSVs are DVC-tracked -> keep only *.dvc pointers.
ml/*/data/
!ml/focus/data/
ml/focus/data/*
!ml/focus/data/*.dvc
!ml/bioage/data/
ml/bioage/data/*
!ml/bioage/data/*.dvc
# Generated native iOS project (Expo managed workflow)
/ios/
# Logs and Office temp/lock files
ml/**/*.log
~$*
