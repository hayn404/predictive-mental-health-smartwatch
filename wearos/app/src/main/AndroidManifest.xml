<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Mark as Wear OS standalone app (no phone app required) -->
    <uses-feature android:name="android.hardware.type.watch" />

    <!-- Health Services permissions (on-watch sensor access) -->
    <uses-permission android:name="android.permission.BODY_SENSORS" />
    <uses-permission android:name="android.permission.BODY_SENSORS_BACKGROUND" />
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Vibration for breathing exercises -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Wake lock for active exercise sessions -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_HEALTH" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".SerenWatchApp"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:theme="@android:style/Theme.DeviceDefault"
        android:allowBackup="true">

        <uses-library
            android:name="com.google.android.wearable"
            android:required="false" />

        <!-- Main Activity (Compose) -->
        <activity
            android:name=".presentation.MainActivity"
            android:exported="true"
            android:taskAffinity=""
            android:theme="@android:style/Theme.DeviceDefault">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Health monitoring foreground service -->
        <service
            android:name=".health.HealthMonitorService"
            android:exported="false"
            android:foregroundServiceType="health" />

        <!-- TODO: Wear Tile Service (implement when Tiles Material 3 is integrated) -->

        <!-- Standalone Wear OS app (no phone companion required) -->
        <meta-data
            android:name="com.google.android.wearable.standalone"
            android:value="true" />

    </application>
</manifest>
