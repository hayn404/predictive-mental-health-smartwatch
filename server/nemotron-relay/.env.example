# server/nemotron-relay — environment template. Copy to `.env` and fill in.

# --- NVIDIA NIM, hosted via NVIDIA Cloud Functions (recommended default) ---
# This is the same gateway NVIDIA's own Riva Python client scripts use; it's
# a single shared gRPC endpoint that routes by the `function-id` metadata
# header below. Leave RIVA_GRPC_HOST/RIVA_USE_SSL as-is for this mode.
RIVA_GRPC_HOST=grpc.nvcf.nvidia.com:443
RIVA_USE_SSL=true

# Get an API key at https://build.nvidia.com (top-right, "Get API Key").
NVIDIA_API_KEY=nvapi-your-key-here

# Pick a hosted ASR model at build.nvidia.com and copy its function-id from
# that model's "API Reference" tab. "nemotron-asr-streaming" is NVIDIA's own
# Nemotron ASR model — search for it on build.nvidia.com if this ID changes:
RIVA_FUNCTION_ID=bb0837de-8c7b-481f-9ec8-ef5663e9c1fa

# --- Self-hosted Riva server (alternative — comment out the block above) ---
# RIVA_GRPC_HOST=your-riva-host:50051
# RIVA_USE_SSL=false
# (leave RIVA_FUNCTION_ID and NVIDIA_API_KEY unset — self-hosted Riva doesn't
#  use NVCF routing or expect an authorization header)

# --- Relay server ---
RELAY_PORT=8088

# Shared secret the Expo app sends as `Authorization: Bearer <secret>` —
# this is a SEPARATE key from NVIDIA_API_KEY, so the phone never carries
# your actual NVIDIA credential. Set EXPO_PUBLIC_NEMOTRON_RELAY_KEY in the
# app's own .env to the same value.
# Leave unset only for local dev on a trusted network — never deploy
# without this set, or anyone who finds the relay's URL can spend your
# NVIDIA API credits.
RELAY_SHARED_SECRET=change-me
