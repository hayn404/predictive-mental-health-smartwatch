{
  "version": "3.2.0",
  "modelType": "tcn_bilstm_seq2seq_hr_actigraphy",
  "task": "sleep_stage_classification_4class",
  "trainData": "BIDSleep (Apple Watch)",
  "testData": "Walch/Sleep-Accel (held-out)",
  "numClasses": 4,
  "stageNames": [
    "Wake",
    "Light",
    "Deep",
    "REM"
  ],
  "stageMap": {
    "0": "awake",
    "1": "light",
    "2": "deep",
    "3": "rem"
  },
  "input": {
    "features": {
      "shape": [
        1,
        41,
        11
      ],
      "names": [
        "hr_mean",
        "hr_std",
        "hr_min",
        "hr_max",
        "hr_range",
        "hr_succdiff_std",
        "hr_delta_prev",
        "act_count",
        "act_max",
        "act_std",
        "time_of_night"
      ],
      "epochSeconds": 30,
      "recommendedSeqLen": 41,
      "normalization": "per_night_median_mad_per_feature"
    }
  },
  "output": {
    "logits": {
      "shape": [
        1,
        41,
        4
      ],
      "note": "argmax last dim -> stageMap"
    }
  },
  "test": {
    "protocol": "BIDSleep -> Walch zero-shot, subject-disjoint",
    "walch_macroF1": 0.6214113322365629,
    "walch_weightedF1": 0.6651198490522063,
    "walch_accuracy": 0.6606,
    "walch_kappa": 0.48206921837871797,
    "perClassRecall": {
      "Wake": 0.470,
      "Light": 0.636,
      "Deep": 0.781,
      "REM": 0.723
    },
    "threeClass": {
      "weightedF1": 0.798,
      "accuracy": 0.799,
      "kappa": 0.561
    }
  }
}